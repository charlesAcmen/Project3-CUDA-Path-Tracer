# Simple cube (12 triangles, 8 vertices)
# Each face is split into 2 triangles

v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5

# Front face (+Z)
f 1 2 3
f 1 3 4

# Back face (-Z)
f 5 7 6
f 5 8 7

# Top face (+Y)
f 3 7 8
f 3 8 4

# Bottom face (-Y)
f 1 5 6
f 1 6 2

# Right face (+X)
f 2 6 7
f 2 7 3

# Left face (-X)
f 5 1 4
f 5 4 8
